# ─── SPOTIFY (PKCE flow — no Client Secret needed!) ───────────────────────────
# 1. Go to https://developer.spotify.com/dashboard
# 2. Create an app → give it any name/description
# 3. In Settings → Redirect URIs → add:  http://localhost:3000/callback.html
#    (Spotify explicitly allows http://localhost — click Add, ignore the warning)
# 4. Copy your Client ID below (Client Secret is NOT needed for PKCE)
SPOTIFY_CLIENT_ID=

# ─── APPLE MUSIC ────────────────────────────────────────────────────────────────
# Developer Token JWT from https://developer.apple.com → Certificates → MusicKit
APPLE_DEVELOPER_TOKEN=

# ─── YOUTUBE SEARCH (optional) ──────────────────────────────────────────────────
# Get a key from https://console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=

# ─── SERVER ─────────────────────────────────────────────────────────────────────
PORT=3000
BASE_URL=http://localhost:3000
